# AlphaForge — Environment Variables
# Copy to .env for local development (NEVER commit .env)

# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Local Development (docker-compose)
DYNAMODB_LOCAL_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE=alpha-signals-dev

# Market Config
WATCHLIST=AAPL,MSFT,NVDA,GOOGL,TSLA,SPY
STRONG_BUY_THRESHOLD=0.75
BUY_THRESHOLD=0.55
WATCH_THRESHOLD=0.35

# AI Budget
MONTHLY_AI_BUDGET=5.00

# API Keys (store in SSM Parameter Store for production — NEVER hardcode)
# Obtain and paste here for local testing only
LINE_NOTIFY_TOKEN=your_line_token_here
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
ALPACA_API_KEY=your_alpaca_key_here
HF_API_KEY=your_huggingface_key_here   # for FinBERT (Phase 2)
